# Example environment variables for development
# Copy to .env and fill in real values. Do NOT commit .env with secrets.

# Public
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# MinIO (object storage used to host posts/assets)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=blog
MINIO_POSTS_PREFIX=posts/
