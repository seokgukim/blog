# Example environment variables for development
# Copy to .env and fill in real values. Do NOT commit .env with secrets.

# Public
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Public S3-compatible source for blog markdown.
# Posts are read from ${S3_PUBLIC_ENDPOINT}${S3_BLOG_PATH}/posts/*.md during build.
# Leave S3_PUBLIC_ENDPOINT unset to build from local content/posts.
S3_PUBLIC_ENDPOINT=https://s3.seokgukim.com
S3_BLOG_PATH=/blog
# Use manifest for the included R2 Worker-generated endpoint; use list only for S3 endpoints with public ListBucket.
S3_POST_DISCOVERY=manifest
